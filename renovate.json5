{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: ["config:best-practices"],

  packageRules: [
    {
      description: "Group tonic packages.",
      matchDepNames: ["/tonic(-.+)?/"],
      groupName: "tonic",
    },
    {
      description: "Group kube + schema packages.",
      matchDepNames: ["kube", "k8s-openapi", "schemars"],
      groupName: "kube",
      separateMajorMinor: false,
      separateMinorPatch: false,
    },
  ],
}
